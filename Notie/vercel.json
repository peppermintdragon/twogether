{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": [
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY"
  ],
  "routes": [
    {
      "src": "/robots.txt",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "src": "/sitemap.xml",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
